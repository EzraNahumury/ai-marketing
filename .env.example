# =============================================================================
# Application base URL
# =============================================================================
# This is the public URL where this app is deployed (no trailing slash).
# All marketplace callback & webhook URLs are derived from this value.
#
# Examples:
#   Local dev (via tunnel):  APP_BASE_URL=https://your-tunnel.ngrok-free.app
#   Staging:                 APP_BASE_URL=https://staging.example.com
#   Production:              APP_BASE_URL=https://app.example.com
#
# NOTE: localhost cannot be used for marketplace production callbacks.
APP_BASE_URL=

# =============================================================================
# Shopee Open Platform
# =============================================================================
# Get these from https://open.shopee.com/ after creating an app.
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_CALLBACK_PATH=/api/shopee/callback
SHOPEE_WEBHOOK_PATH=/api/shopee/webhook

# =============================================================================
# TikTok Shop / Tokopedia Shop Partner Center
# =============================================================================
# Get these from https://partner.tiktokshop.com/ after creating an app.
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_CALLBACK_PATH=/api/tiktok/callback
TIKTOK_WEBHOOK_PATH=/api/tiktok/webhook

# =============================================================================
# Encryption
# =============================================================================
# 32-byte key, hex-encoded (64 hex chars) OR base64-encoded.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: rotate per environment. Never commit a real key.
MARKETPLACE_TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Database (MySQL / MariaDB)
# =============================================================================
# MySQL connection string. Leave blank to use the dev JSON-file fallback
# (see lib/db.ts). Production MUST set this.
#
# Local (XAMPP default — root w/ empty password):
#   DATABASE_URL=mysql://root@127.0.0.1:3306/ai_marketing
#
# Hostinger MySQL (from hPanel → Databases → MySQL Databases):
#   DATABASE_URL=mysql://u123456_aimkt:<password>@<mysql-host>:3306/u123456_aimkt
DATABASE_URL=
